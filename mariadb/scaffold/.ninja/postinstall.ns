if env.os == "windows" then
    shell.exec(".\\bin\\mariadb-install-db.exe --auth-root-authentication-method=normal --datadir=.\\data")
    proc.spawn(".\\bin\\mariadbd.exe --defaults-file=.\\my.ini")
    shell.exec(".\\bin\\mariadb.exe -h 127.0.0.1 -P 3306 -u root --execute=\"source ./init.sql;\"")
else
    shell.exec("./scripts/mariadb-install-db --auth-root-authentication-method=normal --datadir=./data")
    proc.spawn("./bin/mariadbd --defaults-file=./my.ini")
    shell.exec("./bin/mariadb -h 127.0.0.1 -P 3306 -u root < init.sql")
end
